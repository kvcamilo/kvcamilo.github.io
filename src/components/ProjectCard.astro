---
interface Props {
  title: string;
  description: string;
  image: string;
  tech: string[];
  year: number;
  url?: string;
}

const { title, description, image, tech, year, url } = Astro.props;
---

{url ? (
  <a href={url} target="_blank" rel="noopener noreferrer" class="block mb-8 pb-8 border-b border-gray-200 dark:border-gray-700 last:border-b-0 hover:bg-gray-50 dark:hover:bg-gray-800 rounded transition-colors p-4 -m-4">
    <div class="flex flex-col sm:flex-row gap-4 sm:gap-6">
      <img src={image} alt={title} class="w-full sm:w-32 md:w-40 h-40 object-cover rounded bg-gray-100 dark:bg-gray-800 flex-shrink-0" />
      <div class="flex-1 min-w-0">
        <h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-white mb-2">{title}</h3>
        <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mb-3">{description}</p>
        <div class="flex flex-wrap gap-2 mb-3">
          {tech.map((t) => (
            <span class="inline-block bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs px-2 py-1 rounded">{t}</span>
          ))}
        </div>
        <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-500">{year}</p>
      </div>
    </div>
  </a>
) : (
  <div class="mb-8 pb-8 border-b border-gray-200 dark:border-gray-700 last:border-b-0">
    <div class="flex flex-col sm:flex-row gap-4 sm:gap-6">
      <img src={image} alt={title} class="w-full sm:w-32 md:w-40 h-40 object-cover rounded bg-gray-100 dark:bg-gray-800 flex-shrink-0" />
      <div class="flex-1 min-w-0">
        <h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-white mb-2">{title}</h3>
        <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mb-3">{description}</p>
        <div class="flex flex-wrap gap-2 mb-3">
          {tech.map((t) => (
            <span class="inline-block bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs px-2 py-1 rounded">{t}</span>
          ))}
        </div>
        <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-500">{year}</p>
      </div>
    </div>
  </div>
)}
