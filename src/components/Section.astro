---
interface Props {
  id: string;
  title: string;
  subtitle?: string;
  className?: string;
}

const { id, title, subtitle, className = '' } = Astro.props;
---

<section id={id} class={`pt-4 sm:pt-6 pb-8 px-4 sm:px-6 lg:px-8 w-full ${className}`}>
  <div class="w-full">
    <h1 class="text-2xl sm:text-3xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-2 sm:mb-4">{title}</h1>
    {subtitle && <p class="text-xs sm:text-base lg:text-lg text-gray-600 dark:text-gray-400 mb-6 sm:mb-12">{subtitle}</p>}
    <slot />
  </div>
</section>
