---
interface Props {
  company: string;
  role: string;
  startDate: string;
  endDate: string | null;
  current: boolean;
  summary: string;
}

const { company, role, startDate, endDate, current, summary } = Astro.props;

const formatDate = (dateStr: string) => {
  const [year, month] = dateStr.split('-');
  return new Intl.DateTimeFormat('es-ES', { year: 'numeric', month: 'long' }).format(
    new Date(parseInt(year), parseInt(month) - 1)
  );
};
---

<div class="mb-4 sm:mb-8 pb-4 sm:pb-8 border-l-2 border-gray-300 dark:border-gray-700 pl-3 sm:pl-4 last:mb-0">
  <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-1">
    <h3 class="text-xs sm:text-sm lg:text-base font-semibold text-gray-900 dark:text-white">{role}</h3>
    {current && <span class="text-xs bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 px-1.5 py-0.5 rounded flex-shrink-0 text-xs">Actual</span>}
  </div>
  <p class="text-xs sm:text-sm lg:text-base text-gray-600 dark:text-gray-400 font-medium mb-2 sm:mb-3">{company}</p>
  <p class="text-xs text-gray-700 dark:text-gray-300 mb-2 sm:mb-3 leading-relaxed">{summary}</p>
  <p class="text-xs text-gray-500 dark:text-gray-400">
    {formatDate(startDate)} — {endDate ? formatDate(endDate) : 'Presente'}
  </p>
</div>
