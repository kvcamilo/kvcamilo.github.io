---
import Layout from '../../../layouts/Layout.astro';
import BottomNav from '../../../components/BottomNav.astro';
import Section from '../../../components/Section.astro';
import ArticleCard from '../../../components/ArticleCard.astro';

import esTranslations from '../../../data/i18n/es.json';
import enTranslations from '../../../data/i18n/en.json';

export function getStaticPaths() {
  // Load all JSON files eagerly - safe even if some don't exist
  const modules = import.meta.glob('/src/data/*.json', { eager: true }) as Record<string, any>;
  const researchModule = modules['/src/data/research.json'];
  
  // Only generate pages if research.json exists
  if (!researchModule) {
    return [];
  }
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

// Load research data for all languages
const modules = import.meta.glob('/src/data/*.json', { eager: true }) as Record<string, any>;
const researchModule = modules['/src/data/research.json'];

const { lang } = Astro.params;
const currentLang = (lang === 'en' ? 'en' : 'es') as 'es' | 'en';
const t = currentLang === 'en' ? enTranslations : esTranslations;

// Safe to access because getStaticPaths verified it exists
const researchObj = researchModule?.default || researchModule || { es: [], en: [] };
const articles = researchObj[currentLang] || [];
---
---

<Layout title={`${t.research.title}`} description={t.research.subtitle} lang={currentLang}>
  <div class="max-h-[calc(100vh-80px)] overflow-y-auto">
    <Section id="research" title={t.research.title} subtitle={t.research.subtitle}>
    <div>
      {articles.map((article) => (
        <ArticleCard
          title={article.title}
          summary={article.summary}
          date={article.date}
          url={article.url}
          type={article.type}
        />
      ))}
    </div>
  </Section>
  </div>

  <BottomNav currentLang={currentLang} currentPage="research" />
</Layout>
