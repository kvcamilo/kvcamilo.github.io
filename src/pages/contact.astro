<div class="space-y-4 sm:space-y-6">
  <div class="flex items-center gap-4">
    <span class="flex h-14 w-14 shrink-0 items-center justify-center text-4xl leading-none">
      ✉️
    </span>
    <div class="translate-y-2">
      <p class="text-sm text-gray-500 dark:text-gray-400">{t.contact.email}</p>
      <a
        href={`mailto:${contact.email}`}
        class="block text-gray-900 dark:text-white font-medium hover:text-blue-600 dark:hover:text-blue-400"
      >
        {contact.email}
      </a>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <span class="flex h-14 w-14 shrink-0 items-center justify-center text-4xl leading-none">
      📞
    </span>
    <div class="translate-y-2">
      <p class="text-sm text-gray-500 dark:text-gray-400">{t.contact.phone}</p>
      <a
        href={`tel:${contact.phone}`}
        class="block text-gray-900 dark:text-white font-medium hover:text-blue-600 dark:hover:text-blue-400"
      >
        {contact.phone}
      </a>
    </div>
  </div>

  {contact.social && (
    <div class="flex items-center gap-4 pt-4">
      <span class="flex h-14 w-14 shrink-0 items-center justify-center text-4xl leading-none">
        🌐
      </span>
      <div class="translate-y-2">
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">
          {currentLang === 'es' ? 'Redes sociales' : 'Social Links'}
        </p>
        <div class="space-y-8">
          <a href={contact.social.github} target="_blank" rel="noopener" class="block text-gray-900 dark:text-white font-medium hover:text-blue-600 dark:hover:text-blue-400">GitHub</a>
          <a href={contact.social.linkedin} target="_blank" rel="noopener" class="block text-gray-900 dark:text-white font-medium hover:text-blue-600 dark:hover:text-blue-400">LinkedIn</a>
          <a href={contact.social.twitter} target="_blank" rel="noopener" class="block text-gray-900 dark:text-white font-medium hover:text-blue-600 dark:hover:text-blue-400">Twitter</a>
        </div>
      </div>
    </div>
  )}
</div>