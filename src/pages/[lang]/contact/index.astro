---
import Layout from '../../../layouts/Layout.astro';
import BottomNav from '../../../components/BottomNav.astro';
import Section from '../../../components/Section.astro';

import esTranslations from '../../../data/i18n/es.json';
import enTranslations from '../../../data/i18n/en.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const currentLang = (lang === 'en' ? 'en' : 'es') as 'es' | 'en';
const t = currentLang === 'en' ? enTranslations : esTranslations;

// Try to import contact data, use empty object as fallback
let contact = { email: '', phone: '', social: {} };
try {
  const contactData = await import('../../../data/contact.json');
  contact = contactData.default || contactData;
} catch (error) {
  // If contact.json doesn't exist, redirect to home
  return Astro.redirect(`/${currentLang}/`);
}
---

<Layout title={`${t.contact.title}`} description={t.contact.intro} lang={currentLang}>
  <div class="max-h-[calc(100vh-80px)] overflow-y-auto">
    <Section id="contact" title={t.contact.title}>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-12">{t.contact.intro}</p>
    
    <div class="grid md:grid-cols-2 gap-8 md:gap-12">
      <!-- Contact Information -->
      <div>
        <h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-white mb-6">{currentLang === 'es' ? 'Información de contacto' : 'Contact Information'}</h3>
        <div class="space-y-4 sm:space-y-6">
          <div class="flex items-start gap-4">
            <span class="text-2xl">✉️</span>
            <div>
              <p class="text-sm text-gray-500 dark:text-gray-400">{t.contact.email}</p>
              <a href={`mailto:${contact.email}`} class="text-gray-900 dark:text-white font-medium hover:text-blue-600 dark:hover:text-blue-400">{contact.email}</a>
            </div>
          </div>
          
          <div class="flex items-start gap-4">
            <span class="text-2xl">📞</span>
            <div>
              <p class="text-sm text-gray-500 dark:text-gray-400">{t.contact.phone}</p>
              <a href={`tel:${contact.phone}`} class="text-gray-900 dark:text-white font-medium hover:text-blue-600 dark:hover:text-blue-400">{contact.phone}</a>
            </div>
          </div>
          
          {contact.social && (
            <div class="flex items-start gap-4 pt-4">
              <span class="text-2xl">🌐</span>
              <div>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">{currentLang === 'es' ? 'Redes sociales' : 'Social Links'}</p>
                <div class="space-y-2">
                  {Object.entries(contact.social).map(([platform, url]: [string, any]) => (
                    <a
                      href={url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block text-gray-900 dark:text-white font-medium hover:text-blue-600 dark:hover:text-blue-400"
                    >
                      {platform.charAt(0).toUpperCase() + platform.slice(1)}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-gray-50 dark:bg-gray-800 p-6 rounded-lg">
        <h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-white mb-4">{currentLang === 'es' ? 'Envíame un mensaje' : 'Send me a message'}</h3>
        <form class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              {currentLang === 'es' ? 'Nombre' : 'Name'}
            </label>
            <input
              type="text"
              class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
              required
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              Email
            </label>
            <input
              type="email"
              class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
              required
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              {currentLang === 'es' ? 'Mensaje' : 'Message'}
            </label>
            <textarea
              class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white h-32"
              required
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-black dark:bg-white text-white dark:text-black font-medium py-2 rounded-lg hover:bg-gray-800 dark:hover:bg-gray-200 transition-colors"
          >
            {currentLang === 'es' ? 'Enviar' : 'Send'}
          </button>
        </form>
      </div>
    </div>
    </Section>
  </div>

  <BottomNav currentLang={currentLang} currentPage="contact" />
</Layout>
