---
interface Props {
  title: string;
  summary: string;
  date: string;
  url: string;
  type: string;
}

const { title, summary, date, url, type } = Astro.props;

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return new Intl.DateTimeFormat('es-ES', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
};
---

<a href={url} target="_blank" rel="noopener noreferrer" class="block mb-6 pb-6 border-b border-gray-200 dark:border-gray-700 last:border-b-0 hover:bg-gray-50 dark:hover:bg-gray-800 p-2 sm:p-3 rounded transition-colors">
  <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-2">
    <h3 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-white flex-1">{title}</h3>
    <span class="text-xs text-gray-500 dark:text-gray-400 uppercase flex-shrink-0">{type}</span>
  </div>
  <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mb-3">{summary}</p>
  <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-500">{formatDate(date)}</p>
</a>
