---
import Layout from '../../layouts/Layout.astro';
import BottomNav from '../../components/BottomNav.astro';
import Section from '../../components/Section.astro';
import ProjectCarousel from '../../components/ProjectCarousel.astro';

import esTranslations from '../../data/i18n/es.json';
import enTranslations from '../../data/i18n/en.json';

// Check if required data files exist
const dataFiles = import.meta.glob('/src/data/*.json');
const hasProfile = '/src/data/profile.json' in dataFiles;
const hasProjects = '/src/data/projects.json' in dataFiles;

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const currentLang = (lang === 'en' ? 'en' : 'es') as 'es' | 'en';
const t = currentLang === 'en' ? enTranslations : esTranslations;

// Import data only if they exist
let profileData = { name: '', role: '', bio_short: '', location: '', email: '' };
let projectsData: any[] = [];

if (hasProfile) {
  const profileImport = await import('../../data/profile.json');
  const profile = profileImport.default || profileImport;
  profileData = profile[currentLang];
}

if (hasProjects) {
  const projectsImport = await import('../../data/projects.json');
  const projects = projectsImport.default || projectsImport;
  projectsData = projects[currentLang];
}
---

<Layout title={`${profileData.name} - ${profileData.role}`} description={profileData.bio_short} lang={currentLang}>
  <!-- Main content area -->
  <div class="flex flex-col lg:ml-96 max-h-[calc(100vh-80px)] overflow-y-auto">
    <!-- Content section -->
    <div class="flex flex-col items-center justify-center px-4 py-8 lg:py-0">
      <!-- Home Section -->
      <Section id="home" title="">
        <!-- Profile Photo Circle -->
        <div class="mb-8 flex items-center justify-center mt-24">
          <div class="relative">
            <img 
              src="/images/brand-persona.jpg" 
              alt={profileData.name}
              class="w-48 h-48 rounded-full border-8 border-gray-200 dark:border-gray-800 object-cover shadow-lg"
            />
          </div>
        </div>

        <!-- Centered Text Content -->
        <div class="text-center w-full max-w-full px-4">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-3">{profileData.name}</h2>
          <p class="text-base sm:text-lg text-gray-600 dark:text-gray-400 mb-6">{profileData.role}</p>
          <p class="text-sm sm:text-base text-gray-700 dark:text-gray-300 mb-8 leading-relaxed">{profileData.bio_short}</p>
          <div class="space-y-3 sm:space-y-4 text-sm sm:text-base">
            <p class="text-gray-600 dark:text-gray-400">📍 {profileData.location}</p>
            <p class="text-gray-600 dark:text-gray-400">✉️ <a href={`mailto:${profileData.email}`} class="text-blue-600 dark:text-blue-400 hover:underline">{profileData.email}</a></p>
          </div>

          <!-- Expertise and Interests Section - Desktop Only -->
          <div class="hidden lg:block mt-12 pt-8 border-t border-gray-200 dark:border-gray-700 max-w-2xl mx-auto w-full">
            <div class="grid grid-cols-2 gap-8">
              {/* Expertise */}
              <div>
                <h3 class="text-sm sm:text-base lg:text-lg font-semibold text-gray-900 dark:text-white mb-3">{t.about.expertise.title}</h3>
                <p class="text-xs sm:text-sm text-gray-700 dark:text-gray-400 leading-relaxed">
                  {t.about.expertise.items.join(', ')}
                </p>
              </div>

              {/* Interests */}
              <div>
                <h3 class="text-sm sm:text-base lg:text-lg font-semibold text-gray-900 dark:text-white mb-3">{t.about.interests.title}</h3>
                <p class="text-xs sm:text-sm text-gray-700 dark:text-gray-400 leading-relaxed">
                  {t.about.interests.items.join(', ')}
                </p>
              </div>
            </div>
          </div>
        </div>
      </Section>
    </div>

    <!-- Project Carousel - Desktop on left, Mobile below profile -->
    <ProjectCarousel projects={projectsData} lang={currentLang} />
  </div>

  <!-- Navigation Bar at Bottom -->
  <BottomNav currentLang={currentLang} currentPage="home" />
</Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }
</style>
